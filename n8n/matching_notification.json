      "id": "transform_provider_results",
      "name": "Transform: Sort by Composite Score",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [500, 300],
      "notesInFlow": true,
        "notes": "Sort providers by composite_score DESC, take top 10"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Sort providers by composite_score DESC, limit to top 10\nreturn $node[\"spatial_query_providers\"].json.map((provider, index) => ({\n  ...provider,\n  match_rank: index + 1\n})).slice(0, 10);"
      },
      "id": "rank_providers",
      "name": "Code: Rank Providers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "url": "{{ $env.SUPABASE_URL }}/rest/v1/matched_providers",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ $env.SUPABASE_ANON_KEY }}",
          "Content-Type": "application/json"
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "request_id",
              "value": "{{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"id\"] }}"
            },
            {
              "name": "provider_id",
              "value": "{{ $item.json[\"provider_id\"] }}"
            },
            {
              "name": "composite_score",
              "value": "{{ $item.json[\"composite_score\"] }}"
            },
            {
              "name": "distance_miles",
              "value": "{{ $item.json[\"distance_miles\"] }}"
