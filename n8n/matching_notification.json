            {
              "name": "data",
              "value": "{\"request_id\": \"{{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"id\"] }}\", \"match_rank\": {{ $item.json[\"match_rank\"] }}}"
            }
          ]
