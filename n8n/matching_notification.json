            "name": "content",
            "value": "[{\"type\": \"text/html\", \"value\": \"<h2>New Job Match!</h2><p>A customer needs {{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"title\"] }}</p><p><strong>Location:</strong> {{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"address_city\"] }}, {{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"address_state\"] }}</p><p><strong>Budget:</strong> ${{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"budget_min\"] }} - ${{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"budget_max\"] }}</p><p><strong>Distance:</strong> {{ $item.json[\"distance_miles\"] }} miles</p><p><a href=\\\"https://marketplace.example.com/requests/{{ $node[\"supabase_webhook_trigger\"].json[\"record\"][\"id\"] }}\\\">View Job & Submit Bid</a></p>\"}]"
          }
        ]
      },
      "id": "send_email_notification",
