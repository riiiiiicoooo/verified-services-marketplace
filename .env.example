# ============================================================================
# Application Configuration
# ============================================================================

NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://marketplace.example.com
PORT=3000

# ============================================================================
# Supabase (Database & Auth)
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# Clerk Authentication
# ============================================================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=YOUR_CLERK_WEBHOOK_SECRET

# ============================================================================
# Stripe Payments
# ============================================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Platform fee rate (15% default)
STRIPE_PLATFORM_FEE_RATE=0.15

# ============================================================================
# Payment Processing & Escrow
# ============================================================================

# Stripe Connect
STRIPE_ONBOARDING_REFRESH_URL=https://marketplace.example.com/provider/onboarding
STRIPE_ONBOARDING_RETURN_URL=https://marketplace.example.com/provider/dashboard

# ============================================================================
# Third-Party Verification Services
# ============================================================================

# Checkr (Background Checks)
CHECKR_API_KEY=your-checkr-api-key

# License & Insurance Verification APIs
LICENSE_API_KEY=your-license-api-key
INSURANCE_API_KEY=your-insurance-api-key

# ============================================================================
# Email & Notifications
# ============================================================================

# SendGrid (Email)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@marketplace.example.com
SENDGRID_TEMPLATE_ID_BID_NOTIFICATION=d-your-bid-template-id
SENDGRID_TEMPLATE_ID_PROVIDER_WELCOME=d-your-welcome-template-id
SENDGRID_TEMPLATE_ID_BOOKING_CONFIRMATION=d-your-booking-template-id
SENDGRID_TEMPLATE_ID_VERIFICATION_STATUS=d-your-verification-template-id

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+14155552671

# Firebase Cloud Messaging (Push)
FCM_SERVER_KEY=your-fcm-server-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================================================
# Workflow Automation
# ============================================================================

# n8n
N8N_API_URL=https://n8n.example.com/api/v1
N8N_API_KEY=your-n8n-api-key
N8N_PROVIDER_VERIFICATION_WEBHOOK=https://n8n.example.com/webhook/provider-verification
N8N_MATCHING_WEBHOOK=https://n8n.example.com/webhook/matching-notification

# Trigger.dev
TRIGGER_DEV_API_KEY=tr_your_api_key
TRIGGER_DEV_WEBHOOK_URL=https://api.trigger.dev/webhooks/your-webhook-id
MARKETPLACE_BASE_URL=https://marketplace.example.com

# ============================================================================
# Database Configuration
# ============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/marketplace_dev
DATABASE_POOL_SIZE=20

# ============================================================================
# Redis (Caching & Job Queue)
# ============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# Operator Configuration
# ============================================================================

OPERATOR_USER_ID=00000000-0000-0000-0000-000000000000
MARKETPLACE_SUPPORT_EMAIL=support@marketplace.example.com
MARKETPLACE_SUPPORT_PHONE=+1-800-MARKETPLACE

# ============================================================================
# Feature Flags
# ============================================================================

FEATURE_PROVIDER_TIERS=true
FEATURE_BIDDING_WINDOW=true
FEATURE_MILESTONE_PAYMENTS=false
FEATURE_DISPUTES=true

# ============================================================================
# Logging & Monitoring
# ============================================================================

LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-url
DATADOG_API_KEY=your-datadog-api-key

# ============================================================================
# Development Only
# ============================================================================

NEXT_PUBLIC_API_URL=http://localhost:3000
DEBUG=false
MOCK_CHECKR_RESPONSES=false
